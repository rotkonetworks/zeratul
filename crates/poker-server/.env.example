# poker-server — example env. copy to .env and edit.
# CLI flags override env vars; both override the defaults shown here.

# static asset directory (SPA bundle). Defaults to `static/` next to the binary, else `./static`.
# POKER_STATIC_DIR=static

# poker-escrow base URL — unset = real-ZEC features disabled
ESCROW_URL=http://127.0.0.1:3034

# HTTP port to bind
PORT=3000

# log filter (tracing-subscriber EnvFilter syntax)
# RUST_LOG=poker_server=info
