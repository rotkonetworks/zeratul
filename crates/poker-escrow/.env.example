# poker-escrow — example env. copy to .env and edit.
# CLI flags override env vars; both override the defaults shown here.

# house rake address (placeholder until prod wallet wired)
HOUSE_ADDRESS=ztestsapling1...

# zidecar gRPC-web endpoint
ZIDECAR_URL=https://zcash.rotko.net

# on-chain deposit verification (vs self-reported counters): true | false
ESCROW_VERIFY_DEPOSITS=false

# network: main | test | regtest
ESCROW_NETWORK=test

# use DKG (vs trusted-dealer) for key generation: true | false
ESCROW_USE_DKG=false

# FROST relay WebSocket URL (used for DKG + payout signing)
ESCROW_RELAY_URL=ws://127.0.0.1:50053/ws

# HTTP port to bind
ESCROW_PORT=3034

# log filter (tracing-subscriber EnvFilter syntax)
# RUST_LOG=poker_escrow=info,poker_escrow::dkg_room=info,poker_escrow::scanner=info
